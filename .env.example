# Server Configuration
PORT=3000
SERVER_URL=https://mm.sharetrack.org

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_here

# File uploads directory
UPLOAD_DIR=./server/uploads

# AI Configuration (Optional - choose one)

# OpenAI (Paid - ~$0.002 per generation)
# Get your API key at: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key

# Brevo Email (Optional - for invitation emails)
# Get your API key at: https://app.brevo.com/
BREVO_API_KEY=your_brevo_api_key
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=Meeting Manager
